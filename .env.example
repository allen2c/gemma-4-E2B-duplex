# Copy to .env and fill in. The app loads this automatically at startup.

# --- Cartesia TTS (required for speech) ---
# The model emits text; Cartesia sonic-3.5 turns it into speech. Without these keys the app
# still runs and shows the model's text, but you won't hear anything.
# Get an API key and create a voice at https://cartesia.ai
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Model ---
# The published LoRA adapter (loaded from Hugging Face onto google/gemma-4-E2B-it).
# Override only to point at a fork or a local checkpoint directory.
HF_MODEL=dockhardman/gemma-4-E2B-duplex

# --- Optional ---
# Web server port (default 8642). Only used by `python app.py`; with `fastapi run` pass --port.
# PORT=8642
