# Copy to .env and fill in. The app loads this automatically at startup.

# --- Cartesia TTS (required for speech) ---
# The model emits text; Cartesia sonic-3.5 turns it into speech. Without these keys the app
# still runs and shows the model's text, but you won't hear anything.
# Get an API key and create a voice at https://cartesia.ai
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Model ---
# The published LoRA adapter (loaded from Hugging Face onto google/gemma-4-E2B-it).
# Override only to point at a fork or a local checkpoint directory.
HF_MODEL=dockhardman/gemma-4-E2B-duplex

# --- Optional ---
# Web server port (default 8642). Only used by `python app.py`; with `fastapi run` pass --port.
# PORT=8642

# Speech speed, 0.6–1.5 (default 1.5). Cartesia sonic adjusts speaking rate, not pitch.
# CARTESIA_SPEED=1.5

# Engine live-experience guards (tuned defaults; raise the first three for noisier rooms).
# GEMMA_BARGE_RMS=0.045      # mic loudness that counts as a barge-in
# GEMMA_BARGE_MIN_MS=300     # how long it must hold before cutting the reply
# GEMMA_FLOOR_K=3.0          # adaptive silence threshold = noise floor x K
# GEMMA_VOICED_MIN=6         # consecutive voiced frames before a reply is armed
# GEMMA_OPEN_NUDGE=3.0       # nudge toward taking a turn after the user goes quiet (0 disables)
# GEMMA_AGC_TARGET=0.12      # input loudness normalization target (0 disables)
